{
  "name": "eutopia.ts",
  "version": "0.0.7",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run clean && tsc --project tsconfig.json && npm run copy:assets",
    "clean": "rm -rf dist",
    "copy:assets": "cpy '**/*.wgsl' '../dist' --cwd=src",
    "lint": "eslint --max-warnings 0 --cache --cache-strategy content .",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@gribbet/eslint-config": "github:gribbet/eslint-config",
    "@webgpu/types": "^0.1.71",
    "cpy-cli": "^7.0.0",
    "eslint": "^10.7.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.4"
  },
  "dependencies": {
    "wgpu-matrix": "^3.4.2"
  },
  "peerDependencies": {
    "signlets": "^1.0.0"
  }
}
